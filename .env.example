# ============================================
# BlindLane Environment Variables
# ============================================

# Model providers (used as default / BYOK fallback)
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# Platform subscription keys (used when users don't provide their own)
PLATFORM_OPENAI_KEY=
PLATFORM_ANTHROPIC_KEY=
PLATFORM_GOOGLE_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Clerk (auth - required for /admin access)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-key
CLERK_SECRET_KEY=sk_test_your-clerk-secret

# Feature flags
ARENA_MVP_V2=true

# Cost and limits
DAILY_BUDGET_LIMIT=10
RATE_LIMIT_PER_IP=10
MAX_PROMPT_LENGTH=1000
API_TIMEOUT_SECONDS=15
MAX_CONCURRENT_GENERATIONS_GLOBAL=20
MAX_CONCURRENT_GENERATIONS_PER_IP=3
